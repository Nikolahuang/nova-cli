{
  "name": "@nikolahuang1/nova",
  "version": "0.2.6",
  "description": "Next-generation CLI agent framework - efficient, multimodal, intelligent",
  "engines": {
    "bun": ">=1.0.0",
    "node": ">=18.0.0"
  },
  "bin": {
    "nova": "./packages/cli/bin/nova"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "format": "prettier --write \"packages/**/*.ts\"",
    "clean": "turbo run clean && rimraf node_modules dist",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.2.0",
    "rimraf": "^5.0.0",
    "turbo": "^2.8.21",
    "typescript": "^5.9.3",
    "vitest": "^1.4.0"
  },
  "packageManager": "pnpm@9.1.0",
  "dependencies": {
    "abort-controller": "^3.0.0",
    "ignore": "^7.0.5",
    "tsx": "^4.21.0",
    "xlsx": "^0.18.5"
  },
  "optionalDependencies": {
    "docx": "^9.6.1",
    "mammoth": "^1.12.0",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^1.1.4"
  }
}
