# Nova CLI 环境变量配置示例
# 复制此文件为 .env 并填入你的 API Keys

# ===========================================
# 国内模型服务商 (推荐国内用户使用)
# ===========================================

# 智谱 AI (GLM-4, GLM-4-Plus, GLM-4-Flash)
# 获取地址: https://open.bigmodel.cn/
ZHIPU_API_KEY=your_zhipu_api_key_here

# 月之暗面 Moonshot (Kimi)
# 获取地址: https://platform.moonshot.cn/
MOONSHOT_API_KEY=your_moonshot_api_key_here

# 阿里云通义千问 (Qwen)
# 获取地址: https://dashscope.console.aliyun.com/
QWEN_API_KEY=your_qwen_api_key_here

# 百度千帆 (Baichuan)
# 获取地址: https://console.bce.baidu.com/qianfan/
BAICHUAN_API_KEY=your_baichuan_api_key_here

# MiniMax
# 获取地址: https://www.minimax.chat/
MINIMAX_API_KEY=your_minimax_api_key_here

# 零一万物 (Yi)
# 获取地址: https://platform.lingyiwanwu.com/
YI_API_KEY=your_yi_api_key_here

# SiliconFlow (聚合平台，支持多个开源模型)
# 获取地址: https://siliconflow.cn/
SILICONFLOW_API_KEY=your_siliconflow_api_key_here

# LongCat
# 获取地址: https://longcat.chat/
LONGCAT_API_KEY=your_longcat_api_key_here

# ===========================================
# 国际模型服务商
# ===========================================

# Anthropic Claude
# 获取地址: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI (GPT-4, GPT-4o, o1, o3-mini)
# 获取地址: https://platform.openai.com/
OPENAI_API_KEY=your_openai_api_key_here

# Google AI (Gemini)
# 获取地址: https://aistudio.google.com/
GOOGLE_API_KEY=your_google_api_key_here

# DeepSeek
# 获取地址: https://platform.deepseek.com/
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Groq (高速推理)
# 获取地址: https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here

# Mistral AI
# 获取地址: https://console.mistral.ai/
MISTRAL_API_KEY=your_mistral_api_key_here

# Together AI
# 获取地址: https://api.together.xyz/
TOGETHER_API_KEY=your_together_api_key_here

# Perplexity (Sonar)
# 获取地址: https://www.perplexity.ai/
PERPLEXITY_API_KEY=your_perplexity_api_key_here

# ===========================================
# Ollama Cloud (云端 Ollama)
# ===========================================

# Ollama Cloud API Key
# 获取地址: https://ollama.com/
OLLAMA_CLOUD_API_KEY=your_ollama_cloud_api_key_here

# ===========================================
# 自定义 Provider
# ===========================================

# 自定义 OpenAI 兼容 API
# CUSTOM_API_BASE_URL=https://your-api-endpoint.com/v1
# CUSTOM_API_KEY=your_custom_api_key_here

# ===========================================
# 使用说明
# ===========================================

# 1. 复制此文件: cp .env.example .env
# 2. 填入你需要的 API Keys (不需要填满所有)
# 3. 运行 nova 命令时会自动读取配置

# 或者使用 nova CLI 命令配置:
#   nova auth set <provider> --key <your-api-key>
#   nova provider add <url> <key> [-m <model>] [-n <name>]
