{
  "name": "nova-terminal-ai",
  "version": "0.3.4",
  "description": "Nova CLI - Next-generation AI-powered terminal assistant",
  "type": "module",
  "bin": {
    "nova": "./bin/nova.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "bin/",
    "dist/",
    "README.md"
  ],
  "scripts": {
    "start": "node --import tsx bin/nova.js",
    "dev": "node --import tsx bin/nova.js",
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "keywords": [
    "ai",
    "cli",
    "assistant",
    "code",
    "terminal",
    "llm",
    "anthropic",
    "openai",
    "ollama"
  ],
  "author": "Nova CLI Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/nova-cli/nova-cli"
  },
  "bugs": {
    "url": "https://github.com/nova-cli/nova-cli/issues"
  },
  "homepage": "https://github.com/nova-cli/nova-cli#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.25.0",
    "@inquirer/prompts": "^5.3.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "abort-controller": "^3.0.0",
    "chalk": "^5.3.0",
    "cheerio": "^1.2.0",
    "commander": "^12.1.0",
    "diff": "^5.2.0",
    "duck-duck-scrape": "^2.2.7",
    "glob": "^10.3.0",
    "ignore": "^5.3.0",
    "ink": "^4.4.1",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^5.0.1",
    "json-schema": "^0.4.0",
    "mime-types": "^2.1.35",
    "open": "^10.1.0",
    "openai": "^4.28.0",
    "p-limit": "^4.0.0",
    "pdf-parse": "^2.4.5",
    "react": "^18.2.0",
    "semver": "^7.6.0",
    "tesseract.js": "^7.0.0",
    "uuid": "^9.0.0",
    "yaml": "^2.4.0",
    "yargs": "^17.7.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.0",
    "ink-testing-library": "^3.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "tsx": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "tsx": {
      "optional": true
    }
  }
}
