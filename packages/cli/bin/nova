#!/usr/bin/env node

// Nova CLI Entry Point - Cross-platform launcher

import { createRequire } from 'node:module';
import { dirname, join } from 'node:path';
import { fileURLToPath } from 'node:url';

const __filename = fileURLToPath(import.meta.url);
const __dirname = dirname(__filename);
const require = createRequire(import.meta.url);

const mainScript = join(__dirname, 'nova.js');

// Try to use tsx from local node_modules
try {
  const tsxPath = require.resolve('tsx', { paths: [__dirname] });
  import('tsx').then(async ({ default: tsx }) => {
    await tsx.esm(mainScript, process.argv.slice(2));
  }).catch((err) => {
    console.error('Failed to load tsx:', err.message);
    process.exit(1);
  });
} catch {
  console.error('tsx not found. Please install dependencies first.');
  process.exit(1);
}
